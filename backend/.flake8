[flake8]
max-line-length = 88
select = E,W,F,C,N
ignore = 
    E203,  # whitespace before ':'
    E501,  # line too long (handled by black)
    W503,  # line break before binary operator
    E402,  # module level import not at top of file
exclude = 
    .git,
    __pycache__,
    venv,
    .venv,
    .eggs,
    *.egg,
    build,
    dist,
    .tox,
    migrations,
per-file-ignores =
    __init__.py:F401
    tests/*:F401,F811