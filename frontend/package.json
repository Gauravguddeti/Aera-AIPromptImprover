{
  "name": "aera-frontend",
  "version": "0.1.0",
  "description": "Aera AI Prompt Enhancement Tool - Frontend Interface",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src --ext .js,.ts",
    "lint:fix": "eslint src --ext .js,.ts --fix",
    "format": "prettier --write src/**/*.{js,ts,css,html}",
    "format:check": "prettier --check src/**/*.{js,ts,css,html}",
    "serve": "python -m http.server 3000 --directory dist"
  },
  "dependencies": {
    "debounce": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@babel/preset-env": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.8",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.0",
    "babel-jest": "^30.2.0",
    "eslint": "^8.53.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-jest": "^27.6.0",
    "eslint-plugin-react": "^7.33.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.0.3",
    "vite": "^4.5.0"
  },
  "keywords": [
    "ai",
    "prompt",
    "enhancement",
    "frontend",
    "javascript"
  ],
  "author": "Aera Development Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aera-ai/aera"
  },
  "bugs": {
    "url": "https://github.com/aera-ai/aera/issues"
  },
  "homepage": "https://github.com/aera-ai/aera#readme"
}
